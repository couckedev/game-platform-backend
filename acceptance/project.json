{
  "name": "game-platform-acceptance",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": [
    "player-contracts",
    "player-application",
    "player-adapters",
    "shared-adapters"
  ],
  "tags": [
    "type:acceptance"
  ],
  "targets": {
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx node_modules/@cucumber/cucumber/bin/cucumber.js",
        "cwd": "acceptance"
      }
    },
    "dry-run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx node_modules/@cucumber/cucumber/bin/cucumber.js --dry-run",
        "cwd": "acceptance"
      }
    }
  }
}