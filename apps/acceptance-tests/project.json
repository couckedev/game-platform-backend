{
  "name": "acceptance-tests",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": [
    "player-domain",
    "player-application",
    "player-infrastructure",
    "shared-infrastructure",
    "shared-kernels-time"
  ],
  "tags": [
    "type:acceptance"
  ],
  "targets": {
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx node_modules/@cucumber/cucumber/bin/cucumber.js",
        "cwd": "{projectRoot}"
      }
    },
    "dry-run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx node_modules/@cucumber/cucumber/bin/cucumber.js --dry-run",
        "cwd": "{projectRoot}"
      }
    }
  }
}