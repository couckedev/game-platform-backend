{
  "name": "monorepo-modulith-template",
  "private": true,
  "scripts": {
    "build": "pnpm nx run-many --target=build",
    "test": "pnpm nx run-many --target=test",
    "acceptance:run": "pnpm nx run game-platform-acceptance:run",
    "acceptance:dry-run": "pnpm nx run game-platform-acceptance:dry-run",
    "lint": "pnpm nx run-many --target=lint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "format": "prettier --write .",
    "player:test": "pnpm nx run-many --target=test --projects=tag:scope:player"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@nx/eslint": "19.8.14",
    "@nx/js": "19.8.14",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.11.1",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import": "^2.32.0",
    "nx": "19.8.14",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "volta": {
    "node": "24.15.0",
    "pnpm": "9.12.0"
  }
}
