{
  "name": "monorepo-modulith-template",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm nx run-many --target=build",
    "test:unit": "pnpm nx run-many --target=test:unit",
    "acceptance:run": "pnpm nx run acceptance-tests:run",
    "acceptance:dry-run": "pnpm nx run acceptance-tests:dry-run",
    "lint": "pnpm nx run-many --target=lint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "format": "prettier --write .",
    "player:test:unit": "pnpm nx run-many --target=test:unit --projects=tag:scope:player",
    "player:test:integration": "pnpm nx run-many --target=test:integration --projects=tag:scope:player",
    "player-api:serve": "pnpm nx run player-api:serve",
    "player-api:start": "pnpm nx run player-api:start",
    "player:migration:generate": "pnpm nx run-many --target=db:generate --projects=tag:scope:player",
    "player:migration:run": "pnpm nx run-many --target=db:migrate --projects=tag:scope:player"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@nx/eslint": "19.8.14",
    "@nx/js": "19.8.14",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.11.1",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import": "^2.32.0",
    "nx": "19.8.14",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0"
}
