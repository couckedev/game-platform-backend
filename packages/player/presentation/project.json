{
  "name": "player-presentation",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/player/presentation/src",
  "projectType": "library",
  "tags": ["type:presentation", "scope:player"],
  "implicitDependencies": [
    "player-application",
    "player-domain",
    "player-infrastructure",
    "shared-infrastructure",
    "shared-presentation"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/player/presentation"],
      "options": {
        "command": "npx tsc -p packages/player/presentation/tsconfig.lib.json"
      }
    }
  }
}
